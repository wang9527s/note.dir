#include <stdio.h>
#include <stdlib.h>
#include <unistd.h>
#include <string.h>
#include <uv.h>

#ifdef _WIN32
# define pipe(fds) _pipe(fds, 1024, _O_BINARY)
#endif

typedef struct {
    uv_poll_t poll_handle;
    int fd;
    const char* name;
} event_source_t;

uv_loop_t* loop;

// 模拟事件触发：向 pipe 写数据，模拟 "任务触发"
void trigger_event(int fd, const char* msg) {
    write(fd, msg, strlen(msg));
}

// 回调：pipe 触发
void on_event_poll(uv_poll_t* handle, int status, int events) {
    char buffer[128] = {0};
    event_source_t* src = handle->data;
    int len = read(src->fd, buffer, sizeof(buffer));
    if (len > 0) {
        printf("[EVENT] %s: %s\n", src->name, buffer);
    }
}

// 定时器触发器（定时调度模拟）
void on_timer_tick(uv_timer_t* handle) {
    int* fd = (int*)handle->data;
    static int counter = 0;
    char msg[64];
    snprintf(msg, sizeof(msg), "timer tick %d\n", ++counter);
    trigger_event(*fd, msg);
}

int main() {
    loop = uv_default_loop();

    int pipe1[2], pipe2[2];
    pipe(pipe1);  // pipe1[1] 写，pipe1[0] 读
    pipe(pipe2);

    // 事件源 1
    event_source_t* ev1 = malloc(sizeof(event_source_t));
    ev1->fd = pipe1[0];
    ev1->name = "TaskA";
    uv_poll_init(loop, &ev1->poll_handle, ev1->fd);
    ev1->poll_handle.data = ev1;
    uv_poll_start(&ev1->poll_handle, UV_READABLE, on_event_poll);

    // 事件源 2
    event_source_t* ev2 = malloc(sizeof(event_source_t));
    ev2->fd = pipe2[0];
    ev2->name = "TaskB";
    uv_poll_init(loop, &ev2->poll_handle, ev2->fd);
    ev2->poll_handle.data = ev2;
    uv_poll_start(&ev2->poll_handle, UV_READABLE, on_event_poll);

    // 定时器绑定 pipe1
    uv_timer_t* timer1 = malloc(sizeof(uv_timer_t));
    uv_timer_init(loop, timer1);
    timer1->data = &pipe1[1];  // 写端
    uv_timer_start(timer1, on_timer_tick, 1000, 2000);  // 首次延迟1秒，每2秒触发

    // 定时器绑定 pipe2
    uv_timer_t* timer2 = malloc(sizeof(uv_timer_t));
    uv_timer_init(loop, timer2);
    timer2->data = &pipe2[1];
    uv_timer_start(timer2, on_timer_tick, 1500, 3000);  // 首次1.5秒，每3秒

    printf("Starting event loop...\n");
    uv_run(loop, UV_RUN_DEFAULT);

    uv_loop_close(loop);
    return 0;
}
